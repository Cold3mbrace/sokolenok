# Copy to .env and fill in. docker-compose reads this automatically.

# REQUIRED — full public URL (must match your domain and use https on prod)
BASE_URL=https://YOUR_DOMAIN

# Steam Web API key — https://steamcommunity.com/dev/apikey
# (Domain field there must be your real domain.)
STEAM_API_KEY=

# Faceit Data API server key — https://developers.faceit.com
FACEIT_API_KEY=

# Leave as 1 on prod (HTTPS). Set 0 only for local HTTP testing.
COOKIE_SECURE=1

# Secret used to encrypt private messages at rest (AES-256-GCM).
# Set a long random string. If left empty, a random key is generated and
# stored in the data dir (.msgsecret) — fine for single-server setups.
# WARNING: if you change/lose this, existing messages become unreadable.
MESSAGE_SECRET=

# Admin access by SteamID (comma-separated 64-bit IDs). These accounts see /admin.
# Put YOUR SteamID here. No password needed — admin is tied to your Steam login.
ADMIN_STEAMIDS=
